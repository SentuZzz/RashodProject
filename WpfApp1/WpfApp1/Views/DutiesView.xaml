<UserControl x:Class="WpfApp1.Views.DutiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:WpfApp1.Helpers"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,20,0" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Суточные наряды" FontSize="24" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>

                    <CheckBox Grid.Column="1" Content="Скрыть недоступных" 
                              IsChecked="{Binding HideUnavailable}" 
                              Foreground="#64748B" FontSize="13" FontWeight="SemiBold" 
                              VerticalAlignment="Center" Cursor="Hand"/>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Soldiers}" SelectedItem="{Binding SelectedSoldier}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White"
                          RowBackground="#F9F9F9" AlternatingRowBackground="#FFFFFF" HeadersVisibility="Column"
                          BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0"
                          SelectionChanged="DataGrid_SelectionChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Звание" Binding="{Binding RankName}" Width="Auto" MinWidth="80"/>

                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*" MinWidth="130"/>

                        <DataGridTemplateColumn Header="Статус" Width="Auto" MinWidth="100" SortMemberPath="CurrentStatus">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="5,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#ECFDF5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Отпуск">
                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Госпиталь">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Командировка">
                                                        <Setter Property="Background" Value="#FFFBEB"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="В наряде">
                                                        <Setter Property="Background" Value="#F3E8FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding CurrentStatus}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Отпуск">
                                                            <Setter Property="Foreground" Value="#3B82F6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Госпиталь">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Командировка">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="В наряде">
                                                            <Setter Property="Foreground" Value="#9333EA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Тип службы" Width="Auto" MinWidth="90" SortMemberPath="ServiceType">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="5,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ServiceType}" Value="По контракту">
                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding ServiceType}" FontSize="11" FontWeight="Bold" Foreground="#64748B">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ServiceType}" Value="По контракту">
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="*" MinWidth="100"/>
                        <DataGridTextColumn Header="Подразделение" Binding="{Binding UnitName}" Width="*" MinWidth="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Назначение" FontSize="18" FontWeight="Bold" Foreground="#344E41" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                        <fa:IconImage Icon="CalendarAlt" Foreground="#3B82F6" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Дата наряда:" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <DatePicker SelectedDate="{Binding SelectedDate}" Width="140" Height="30" FontSize="14" Cursor="Hand"/>
                    </StackPanel>

                    <Expander Header="Чек-лист на дату" Margin="0,0,0,20" Foreground="#1E293B" FontWeight="Bold" FontSize="13" IsExpanded="True">
                        <ItemsControl ItemsSource="{Binding DailyDutiesStatus}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <fa:IconImage Grid.Column="0" Icon="{Binding IconName, Mode=OneWay}" Foreground="{Binding StatusColor, Mode=OneWay}" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DutyName}" FontSize="13" Foreground="#1E293B" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusColor, Mode=OneWay}" VerticalAlignment="Center">
                                            <Run Text="{Binding Assigned, Mode=OneWay}"/>
                                            <Run Text="/" Foreground="Gray"/>
                                            <Run Text="{Binding Capacity, Mode=OneWay}" Foreground="Gray"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <TextBlock Text="Выберите военнослужащего слева..." Foreground="#94A3B8" FontStyle="Italic"
                               Visibility="{Binding SelectedSoldier, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Visible}"/>

                    <StackPanel Visibility="{Binding SelectedSoldier, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                        <TextBlock Text="Военнослужащий:" Foreground="#94A3B8" FontSize="11" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding SelectedSoldier.FullName}" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding SelectedSoldier.RankName}" FontSize="13" Foreground="#334155"/>

                        <Border Background="#F1F5F9" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Доступные наряды:" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding AvailableDuties}" SelectedItem="{Binding SelectedDuty}" DisplayMemberPath="DutyName" Height="30" Margin="0,0,0,15"/>

                                <TextBlock Text="Дата заступления:" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button Command="{Binding ToggleCustomDateCommand}" Background="Transparent" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                                        <fa:IconImage Width="18" Height="18">
                                            <fa:IconImage.Style>
                                                <Style TargetType="fa:IconImage">
                                                    <Setter Property="Icon" Value="CalendarPlus"/>
                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCustomDateVisible}" Value="True">
                                                            <Setter Property="Icon" Value="Times"/>
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </fa:IconImage.Style>
                                        </fa:IconImage>
                                    </Button>

                                    <TextBlock Text="{Binding SelectedDate, StringFormat='{}{0:dd.MM.yyyy} (По плану)'}" 
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1E293B">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustomDateVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <DatePicker SelectedDate="{Binding CustomAssignDate}" 
                                                helpers:DatePickerHelper.BlackoutDates="{Binding BusyDates}" 
                                                Width="140" VerticalAlignment="Center" Cursor="Hand">
                                        <DatePicker.Style>
                                            <Style TargetType="DatePicker">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustomDateVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DatePicker.Style>
                                        <DatePicker.CalendarStyle>
                                            <Style TargetType="Calendar">
                                                <Setter Property="CalendarDayButtonStyle">
                                                    <Setter.Value>
                                                        <Style TargetType="CalendarDayButton">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsBlackedOut" Value="True">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                    <Setter Property="ToolTip">
                                                                        <Setter.Value>
                                                                            <MultiBinding Converter="{StaticResource DateTooltipConverter}">
                                                                                <Binding/>
                                                                                <Binding Path="DataContext.BusyDatesInfo" RelativeSource="{RelativeSource AncestorType=Calendar}"/>
                                                                            </MultiBinding>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </DatePicker.CalendarStyle>
                                    </DatePicker>
                                </StackPanel>

                                <Button Content="Назначить в наряд" Command="{Binding AssignDutyCommand}" Height="35" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>