<UserControl x:Class="WpfApp1.Views.DutiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:WpfApp1.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Text="СУТОЧНЫЕ НАРЯДЫ" Foreground="{StaticResource secondaryBackBrush}" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <DataGrid Grid.Column="0" Grid.Row="1" ItemsSource="{Binding Soldiers}" SelectedItem="{Binding SelectedSoldier}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White"
                  RowBackground="#F9F9F9" AlternatingRowBackground="#FFFFFF" HeadersVisibility="Column"
                  BorderThickness="0" Margin="0,0,20,0" SelectionChanged="DataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding SoldierID}" Width="20"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Звание" Binding="{Binding RankName}" Width="100"/>
                <!-- Бейджик типа службы -->
                <DataGridTemplateColumn Header="Тип службы" Width="90" SortMemberPath="ServiceType">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="5,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#EEEEEE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ServiceType}" Value="По контракту">
                                                <Setter Property="Background" Value="#D4EDDA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ServiceType}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#666666"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ServiceType}" Value="По контракту">
                                                    <Setter Property="Foreground" Value="#155724"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="110"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding UnitName}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Назначение" FontSize="18" FontWeight="Bold" Foreground="#344E41" Margin="0,0,0,20"/>
                <TextBlock Text="Выберите военнослужащего в таблице..." Foreground="Gray" TextWrapping="Wrap" Visibility="{Binding SelectedSoldier, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Visible}"/>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSoldier}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Военнослужащий:" Foreground="Gray" FontSize="12" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedSoldier.FullName}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedSoldier.RankName}" FontSize="14"/>
                    <TextBlock Text="Должность:" Foreground="Gray" FontSize="12" Margin="0,15,0,0"/>
                    <TextBlock Text="{Binding SelectedSoldier.PositionName}" FontSize="14" TextWrapping="Wrap"/>
                    <TextBlock Text="Подразделение:" Foreground="Gray" FontSize="12" Margin="0,15,0,0"/>
                    <TextBlock Text="{Binding SelectedSoldier.UnitName}" FontSize="14"/>

                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,25,0,0">
                        <StackPanel>
                            <TextBlock Text="Параметры наряда" FontSize="14" FontWeight="Bold" Foreground="#344E41" Margin="0,0,0,15"/>
                            <TextBlock Text="Выберите наряд:" Foreground="Gray" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding AvailableDuties}" SelectedItem="{Binding SelectedDuty}" DisplayMemberPath="DutyName" Margin="0,5,0,15" Height="30" Padding="5"/>
                            <TextBlock Text="Дата заступления:" Foreground="Gray" FontSize="12"/>

                            <DatePicker SelectedDate="{Binding SelectedDate}" helpers:DatePickerHelper.BlackoutDates="{Binding BusyDates}" Margin="0,5,0,20" Height="30">
                                <DatePicker.CalendarStyle>
                                    <Style TargetType="Calendar">
                                        <Setter Property="CalendarDayButtonStyle">
                                            <Setter.Value>
                                                <Style TargetType="CalendarDayButton">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsBlackedOut" Value="True">
                                                            <Setter Property="Background" Value="#FFDDDD"/>
                                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                                            <Setter Property="ToolTip">
                                                                <Setter.Value>
                                                                    <!-- Убедись, что StaticResource имя совпадает с тем, что в App.xaml -->
                                                                    <MultiBinding Converter="{StaticResource DateTooltipConverter}">
                                                                        <Binding/>
                                                                        <Binding Path="DataContext.BusyDatesInfo" RelativeSource="{RelativeSource AncestorType=Calendar}"/>
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DatePicker.CalendarStyle>
                            </DatePicker>

                            <Button Content="Назначить" Command="{Binding AssignDutyCommand}" Height="35" Background="#344E41" Foreground="White" BorderThickness="0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>