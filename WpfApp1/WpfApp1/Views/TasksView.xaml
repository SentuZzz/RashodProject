<UserControl x:Class="WpfApp1.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <!-- Шаблон карточки задачи -->
        <DataTemplate x:Key="TaskCardTemplate">
            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" Cursor="Hand"
                    PreviewMouseLeftButtonDown="TaskCard_PreviewMouseLeftButtonDown"
                    MouseMove="TaskCard_MouseMove">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.05" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Категория -->
                        <Border Background="{Binding CategoryColor}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding CategoryName}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <!-- Дедлайн -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <fa:IconImage Icon="Clock" Width="12" Height="12" Foreground="#94A3B8" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding DeadlineText}" FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <!-- Название -->
                    <TextBlock Text="{Binding TaskName}" FontSize="15" FontWeight="Bold" Foreground="#1E293B" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <!-- Исполнители -->
                    <ItemsControl ItemsSource="{Binding AssignedSoldiers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullName}" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Стиль для ListView (Колонки Канбана) -->
        <Style x:Key="KanbanColumnStyle" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- К выполнению -->
            <ColumnDefinition Width="*"/>
            <!-- В процессе -->
            <ColumnDefinition Width="*"/>
            <!-- Выполнено -->
            <ColumnDefinition Width="320"/>
            <!-- Панель создания -->
        </Grid.ColumnDefinitions>

        <!-- Колонка 1: К выполнению -->
        <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="10" Margin="0,0,15,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="К выполнению" FontSize="16" FontWeight="Bold" Foreground="#475569" Margin="5,5,0,15"/>
                <ListView Grid.Row="1" ItemsSource="{Binding TodoTasks}" ItemTemplate="{StaticResource TaskCardTemplate}" 
                          Style="{StaticResource KanbanColumnStyle}" AllowDrop="True" Tag="К выполнению" Drop="ListView_Drop"/>
            </Grid>
        </Border>

        <!-- Колонка 2: В процессе -->
        <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="10" Margin="0,0,15,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="В процессе" FontSize="16" FontWeight="Bold" Foreground="#3B82F6" Margin="5,5,0,15"/>
                <ListView Grid.Row="1" ItemsSource="{Binding InProgressTasks}" ItemTemplate="{StaticResource TaskCardTemplate}" 
                          Style="{StaticResource KanbanColumnStyle}" AllowDrop="True" Tag="В процессе" Drop="ListView_Drop"/>
            </Grid>
        </Border>

        <!-- Колонка 3: Выполнено -->
        <Border Grid.Column="2" Background="#F1F5F9" CornerRadius="10" Margin="0,0,15,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Выполнено" FontSize="16" FontWeight="Bold" Foreground="#10B981" Margin="5,5,0,15"/>
                <ListView Grid.Row="1" ItemsSource="{Binding DoneTasks}" ItemTemplate="{StaticResource TaskCardTemplate}" 
                          Style="{StaticResource KanbanColumnStyle}" AllowDrop="True" Tag="Выполнено" Drop="ListView_Drop"/>
            </Grid>
        </Border>

        <!-- Панель создания задачи -->
        <Border Grid.Column="3" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Новая задача" FontSize="18" FontWeight="Bold" Foreground="#344E41" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Что нужно сделать?" Foreground="Gray" FontSize="12"/>
                        <TextBox Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" Padding="5"/>

                        <TextBlock Text="Категория:" Foreground="Gray" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="CategoryName" Margin="0,5,0,15" Height="30"/>

                        <TextBlock Text="Дедлайн (до какого времени):" Foreground="Gray" FontSize="12"/>
                        <!-- Используем DateTimePicker, если есть из пакетов, или обычный TextBox/DatePicker -->
                        <DatePicker SelectedDate="{Binding NewTaskDeadline, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,20" Height="30"/>

                        <TextBlock Text="Назначить свободных бойцов:" Foreground="Gray" FontSize="12" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding AvailableSoldiers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsEnabled}" Margin="0,0,0,8" ToolTip="{Binding TooltipText}">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconImage Icon="{Binding StatusIcon}" Foreground="{Binding StatusColor}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Soldier.FullName}" FontSize="13" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#1E293B"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Создать задачу" Command="{Binding CreateTaskCommand}" Height="40" Background="#344E41" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,15,0,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>