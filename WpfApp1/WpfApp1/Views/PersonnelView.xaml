<UserControl x:Class="WpfApp1.Views.PersonnelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="White" CornerRadius="10" Margin="20" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Личный состав" FontSize="24" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Command="{Binding OpenAddFormCommand}" Background="#3B82F6" Foreground="White" BorderThickness="0" Padding="15,0" Height="35" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Plus" Foreground="White" Width="12" Height="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Добавить бойца" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Border Grid.Column="4" Background="#F1F5F9" CornerRadius="6" Height="35">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Grid.Column="0" Icon="Search" Foreground="#94A3B8" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" 
                                     FontSize="14" Foreground="#334155"/>
                            <TextBlock Grid.Column="1" Text="Поиск (ФИО, Звание...)" Foreground="#94A3B8" VerticalAlignment="Center" Margin="5,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery.Length}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Soldiers}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                          Background="White" RowBackground="#F9F9F9" AlternatingRowBackground="#FFFFFF" 
                          HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Звание" Binding="{Binding RankName}" Width="110" MinWidth="100"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullNameExpanded}" Width="*" MinWidth="220"/>
                        <DataGridTextColumn Header="Тип службы" Binding="{Binding ServiceType}" Width="110" MinWidth="100"/>
                        <DataGridTextColumn Header="Зачислен" Binding="{Binding JoinDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="90" MinWidth="90"/>
                        <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="150" MinWidth="130"/>
                        <DataGridTextColumn Header="Подразделение" Binding="{Binding UnitName}" Width="120" MinWidth="120"/>

                        <DataGridTemplateColumn Header="Статус" Width="Auto" MinWidth="100" SortMemberPath="CurrentStatus">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="5,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#ECFDF5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="На задаче">
                                                        <Setter Property="Background" Value="#FFF7ED"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Отпуск">
                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Госпиталь">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Командировка">
                                                        <Setter Property="Background" Value="#FFFBEB"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="В наряде">
                                                        <Setter Property="Background" Value="#F3E8FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding CurrentStatus}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="На задаче">
                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Отпуск">
                                                            <Setter Property="Foreground" Value="#3B82F6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Госпиталь">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Командировка">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="В наряде">
                                                            <Setter Property="Foreground" Value="#9333EA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Действия" Width="100" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.OpenStatusFormCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Изменить статус" Margin="0,0,12,0">
                                            <fa:IconImage Icon="UserClock" Foreground="#F59E0B" Width="14" Height="14"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.EditSoldierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Редактировать карточку" Margin="0,0,10,0">
                                            <fa:IconImage Icon="PenToSquare" Foreground="#3B82F6" Width="14" Height="14"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteSoldierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding SoldierID}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Уволить в запас">
                                            <fa:IconImage Icon="UserMinus" Foreground="#EF4444" Width="14" Height="14"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Background="#66000000" Panel.ZIndex="100">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFormOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsStatusFormOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Visibility="{Binding IsFormOpen, Converter={StaticResource BoolToVis}}" Background="White" CornerRadius="10" Padding="25" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.2" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding FormTitle}" FontSize="18" FontWeight="Bold" Foreground="#344E41" VerticalAlignment="Center" TextWrapping="Wrap"/>

                        <Button Grid.Column="1" Command="{Binding ToggleBulkModeCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Переключить режим ввода (Один боец / Целый список)">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Users" Foreground="#3B82F6" Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="Списком" Foreground="#3B82F6" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500" Padding="0,0,5,0">
                        <StackPanel>
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBulkInsertMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Фамилия:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <TextBlock Text="Имя:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <TextBlock Text="Отчество:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBulkInsertMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Список ФИО (каждый с новой строки):" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding BulkInsertText, UpdateSourceTrigger=PropertyChanged}" Height="150" AcceptsReturn="True" TextWrapping="Wrap" Padding="10" VerticalContentAlignment="Top" Margin="0,0,0,15">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>

                            <TextBlock Text="Дата зачисления:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding JoinDate}" Height="35" Margin="0,0,0,15"/>

                            <TextBlock Text="Звание:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding Ranks}" SelectedItem="{Binding SelectedRank}" DisplayMemberPath="Name" Height="35" Margin="0,0,0,15"
                                      IsEnabled="{Binding IsSingleInsertMode}" ToolTip="При добавлении списка звание жестко фиксируется (Рядовой)"/>

                            <TextBlock Text="Должность:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding Positions}" SelectedItem="{Binding SelectedPosition}" DisplayMemberPath="Name" Height="35" Margin="0,0,0,15"
                                      IsEnabled="{Binding IsSingleInsertMode}" ToolTip="При добавлении списка должность жестко фиксируется (Стрелок)"/>

                            <TextBlock Text="Подразделение:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding Units}" SelectedItem="{Binding SelectedUnit}" DisplayMemberPath="Name" Height="35" Margin="0,0,0,15"
                                      IsEnabled="{Binding IsSingleInsertMode}" ToolTip="При добавлении списка подразделение жестко фиксируется (назначается ВМП)"/>

                            <TextBlock Text="Тип службы:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding ServiceTypes}" SelectedItem="{Binding SelectedServiceType}" Height="35" Margin="0,0,0,15"
                                      IsEnabled="{Binding IsSingleInsertMode}" ToolTip="При добавлении списка тип службы жестко фиксируется (По призыву)"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding SaveSoldierCommand}" Content="{Binding SubmitButtonText}" 
                                Background="#344E41" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="2" Command="{Binding CancelEditCommand}" 
                                Content="Отмена" Background="#EF4444" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Visibility="{Binding IsStatusFormOpen, Converter={StaticResource BoolToVis}}" Background="White" CornerRadius="10" Padding="25" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.2" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Смена статуса" FontSize="18" FontWeight="Bold" Foreground="#F59E0B" Margin="0,0,0,20"/>

                    <TextBlock Text="Новый статус:" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableStatuses}" SelectedItem="{Binding SelectedStatusType}" Height="35" Margin="0,0,0,15"/>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedStatusType}" Value="В строю">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="С какого числа:" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding StatusStartDate}" Height="35" Margin="0,0,0,15"/>

                        <TextBlock Text="По какое число (включительно):" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding StatusEndDate}" Height="35" Margin="0,0,0,25"/>
                    </StackPanel>

                    <TextBlock Text="Боец будет возвращен в строй автоматически по истечении срока." Foreground="#10B981" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedStatusType}" Value="В строю">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Применить" Command="{Binding SaveStatusCommand}" Height="40" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" Content="Отмена" Command="{Binding CancelStatusCommand}" Height="40" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="10,0,0,0" Padding="15,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>