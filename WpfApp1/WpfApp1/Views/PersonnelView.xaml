<UserControl x:Class="WpfApp1.Views.PersonnelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть: Поиск и Таблица -->
        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,20,0" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Шапка и Поиск -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Личный состав" FontSize="24" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>

                    <!-- Строка поиска -->
                    <Border Grid.Column="2" Background="#F1F5F9" CornerRadius="6" Height="35">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Grid.Column="0" Icon="Search" Foreground="#94A3B8" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" 
                                     FontSize="14" Foreground="#334155"/>
                            <TextBlock Grid.Column="1" Text="Поиск (ФИО, Звание...)" Foreground="#94A3B8" VerticalAlignment="Center" Margin="5,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery.Length}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Таблица бойцов -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Soldiers}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                          Background="White" RowBackground="#F9F9F9" AlternatingRowBackground="#FFFFFF" 
                          HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Звание" Binding="{Binding RankName}" Width="120"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Должность" Binding="{Binding PositionName}" Width="150"/>
                        <DataGridTextColumn Header="Подразделение" Binding="{Binding UnitName}" Width="120"/>

                        <!-- Колонка статуса -->
                        <DataGridTemplateColumn Header="Статус" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="5,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#ECFDF5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="В строю">
                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Отпуск">
                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Госпиталь">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentStatus}" Value="Командировка">
                                                        <Setter Property="Background" Value="#FFFBEB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding CurrentStatus}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="В строю">
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Отпуск">
                                                            <Setter Property="Foreground" Value="#3B82F6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Госпиталь">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CurrentStatus}" Value="Командировка">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Кнопки действий (Редактировать / Удалить) -->
                        <DataGridTemplateColumn Header="Действия" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.EditSoldierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Редактировать" Margin="0,0,10,0">
                                            <fa:IconImage Icon="PenToSquare" Foreground="#3B82F6" Width="14" Height="14"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteSoldierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding SoldierID}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Уволить в запас">
                                            <fa:IconImage Icon="UserMinus" Foreground="#EF4444" Width="14" Height="14"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Правая часть: Форма добавления/редактирования -->
        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding FormTitle}" FontSize="20" FontWeight="Bold" Foreground="#344E41" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                    <StackPanel>
                        <!-- ФИО -->
                        <TextBlock Text="Фамилия:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <TextBlock Text="Имя:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <TextBlock Text="Отчество:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- Справочники -->
                        <TextBlock Text="Звание:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Ranks}" SelectedItem="{Binding SelectedRank}" DisplayMemberPath="Name" Height="35" Margin="0,0,0,15"/>

                        <TextBlock Text="Должность:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Positions}" SelectedItem="{Binding SelectedPosition}" DisplayMemberPath="Name" Height="35" Margin="0,0,0,15"/>

                        <TextBlock Text="Подразделение:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Units}" SelectedItem="{Binding SelectedUnit}" DisplayMemberPath="Name" Height="35" Margin="0,0,0,15"/>

                        <TextBlock Text="Тип службы:" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding ServiceTypes}" SelectedItem="{Binding SelectedServiceType}" Height="35" Margin="0,0,0,15"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопки управления формой -->
                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding SaveSoldierCommand}" Content="{Binding SubmitButtonText}" 
                            Background="#344E41" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="1" Command="{Binding CancelEditCommand}" Visibility="{Binding CancelButtonVisibility}" 
                            Content="Отмена" Background="#EF4444" Foreground="White" FontWeight="Bold" Height="40" Padding="15,0" Margin="10,0,0,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</UserControl>