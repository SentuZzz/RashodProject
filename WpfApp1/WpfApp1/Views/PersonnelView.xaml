<UserControl x:Class="WpfApp1.Views.PersonnelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Text="ЛИЧНЫЙ СОСТАВ" Foreground="{StaticResource secondaryBackBrush}" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Таблица -->
        <DataGrid Grid.Column="0" Grid.Row="1" ItemsSource="{Binding Soldiers}" SelectedItem="{Binding SelectedSoldier}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White"
                  RowBackground="#F9F9F9" AlternatingRowBackground="#FFFFFF" HeadersVisibility="Column"
                  BorderThickness="0" Margin="0,0,20,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding SoldierID}" Width="50"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding UnitName}" Width="120"/>
                <DataGridTextColumn Header="Звание" Binding="{Binding RankName}" Width="120"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <!-- Сюда мы позже добавим колонку "Текущий статус" -->
            </DataGrid.Columns>
        </DataGrid>

        <!-- Правая панель (Заглушка под статусы) -->
        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Управление статусом" FontSize="18" FontWeight="Bold" Foreground="#344E41" Margin="0,0,0,20"/>
                <TextBlock Text="Скоро здесь появится панель управления отпусками, госпиталями и командировками." Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>