<UserControl x:Class="WpfApp1.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Главная панель" FontSize="26" FontWeight="Bold" Foreground="{StaticResource secondaryBackBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentDate}" FontSize="16" Foreground="#7F8C8D" Margin="0,0,15,3" VerticalAlignment="Bottom"/>
                <TextBlock Text="{Binding CurrentTime}" FontSize="28" FontWeight="Bold" Foreground="#344E41" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Grid>
        <UniformGrid Grid.Row="1" Rows="1" Columns="{Binding GridColumnsCount}" Margin="-10,0,-10,20">

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="50" Height="50" CornerRadius="25" Background="#F1F5F9">
                        <fa:IconImage Icon="Users" Foreground="#475569" Width="24" Height="24"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Всего по списку" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="50" Height="50" CornerRadius="25" Background="#DCFCE7">
                        <fa:IconImage Icon="UserCheck" Foreground="#16A34A" Width="24" Height="24"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="В строю" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding InFormationCount}" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="50" Height="50" CornerRadius="25" Background="#FEE2E2">
                        <fa:IconImage Icon="UserMinus" Foreground="#DC2626" Width="24" Height="24"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Отсутствуют" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding AbsentCount}" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="50" Height="50" CornerRadius="25" Background="#E0F2FE">
                        <fa:IconImage Icon="ShieldHalved" Foreground="#0284C7" Width="24" Height="24"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="В наряде" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OnDutyCount}" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10" Visibility="{Binding IsVmpVisible}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="50" Height="50" CornerRadius="25" Background="#EEF2FF">
                        <fa:IconImage Icon="UserGraduate" Foreground="#6366F1" Width="24" Height="24"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ВМП" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding VmpCount}" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </UniformGrid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <fa:IconImage Icon="Bell" Foreground="#F59E0B" Width="20" Height="20" Margin="0,0,10,0"/>
                                <TextBlock Text="Планирование (Завтра)" FontSize="16" FontWeight="Bold" Foreground="#344E41"/>
                            </StackPanel>
                            <Button Content="{Binding ToggleChecklistText}" Command="{Binding ToggleChecklistCommand}" 
                                     HorizontalAlignment="Right" Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Cursor="Hand"/>
                        </Grid>

                        <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                            <ItemsControl ItemsSource="{Binding VisiblePlanningDuties}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <fa:IconImage Grid.Column="0" Icon="{Binding IconName, Mode=OneWay}" Foreground="{Binding StatusColor, Mode=OneWay}" Width="20" Height="20" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DutyName}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText, Mode=OneWay}" Foreground="{Binding StatusColor, Mode=OneWay}" FontWeight="Bold" FontSize="11"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <ItemsControl ItemsSource="{Binding ActiveDutyCards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#9CA3AF" CornerRadius="8" Padding="15" Margin="0,0,0,15" VerticalAlignment="Top">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.1" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <Grid Grid.IsSharedSizeScope="True">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="{Binding GroupName}" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>

                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding PersonnelRoles}" Margin="0,0,0,20">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding RoleName}" Foreground="#F8FAFC" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        <Border Grid.Column="1" Width="2" Background="#D1D5DB" Margin="8,0" CornerRadius="1"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding PersonnelName}" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Grid Grid.Row="2">
                                            <Border Background="#4D7C5F" CornerRadius="4" Padding="15,4" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding ShiftPeriod}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveDutyCards.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                                                        <fa:IconImage Icon="ShieldBlank" Foreground="#CBD5E1" Width="48" Height="48" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Наряды отсутствуют" Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <fa:IconImage Icon="CalendarAlt" Foreground="#3B82F6" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Ближайшие события" FontSize="16" FontWeight="Bold" Foreground="#344E41" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding UpcomingEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="4" Padding="2,5" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DateString}" FontSize="11" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:IconImage Icon="{Binding IconName, Mode=OneWay}" Foreground="{Binding IconColor, Mode=OneWay}" Width="14" Height="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding SoldierName}" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                                                </StackPanel>
                                                <TextBlock Margin="20,2,0,0" FontSize="12" Foreground="#64748B">
                                                    <Run Text="{Binding ActionText, Mode=OneWay}"/>
                                                    <Run Text="{Binding StatusName}" Foreground="{Binding IconColor, Mode=OneWay}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UpcomingEvents.Count}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <StackPanel HorizontalAlignment="Center" Margin="0,30,0,0">
                                                            <fa:IconImage Icon="CheckDouble" Foreground="#CBD5E1" Width="32" Height="32" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="Нет запланированных убытий" Foreground="#94A3B8" FontStyle="Italic" Margin="0,10,0,0"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>