<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:views="clr-namespace:WpfApp1.Views"
        xmlns:viewmodels="clr-namespace:WpfApp1.ViewModels"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:PersonnelViewModel}">
            <views:PersonnelView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:DutiesViewModel}">
            <views:DutiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:TasksViewModel}">
            <views:TasksView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="10"
            BorderThickness="1"
            BorderBrush="{StaticResource secondaryBackBrush}"
            Background="{StaticResource primaryBackBrush}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--_Навигационное меню_-->
            <Border Grid.Column="0"
                    CornerRadius="10,0,0,10"
                    Background="{StaticResource secondaryBackBrush}">
                <StackPanel>
                    <!--Логотип-->
                    <StackPanel Orientation="Horizontal" Height="35" Margin="15,25,0,40">
                        <Image Source="/Images/ArmyLogo.png" Height="30" Margin="10,0,0,0"/>
                        <TextBlock Text="РАСХОД"
                                   Foreground="{StaticResource primaryTextBrush}"
                                   FontSize="20"
                                   FontFamily="Montserrat"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Дашборд -->
                    <RadioButton Style="{StaticResource menuButton}"
                                 IsChecked="True"
                                 Command="{Binding ShowHomeViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Home" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Главная" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Личный состав -->
                    <RadioButton Style="{StaticResource menuButton}"
                                 Command="{Binding ShowPersonnelViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="UserGroup" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Личный состав" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Наряды -->
                    <RadioButton Style="{StaticResource menuButton}"
                                 Command="{Binding ShowDutiesViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ShieldHalved" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Наряды" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Рабочие команды -->
                    <RadioButton Style="{StaticResource menuButton}"
                                 Command="{Binding ShowTasksViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ClipboardList" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Рабочие команды" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Журнал -->
                    <RadioButton Style="{StaticResource menuButton}"
                                 Command="{Binding ShowHistoryViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ClockRotateLeft" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Журнал" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Справочники -->
                    <RadioButton Style="{StaticResource menuButton}"
                                 Command="{Binding ShowSettingsViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Gears" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Справочники" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Документы -->
                    <RadioButton Style="{StaticResource menuButton}"
                                 Command="{Binding ShowReportsViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="FileContract" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Документы" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </RadioButton>

                </StackPanel>
            </Border>

            <!--_Основной контент_-->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <!-- Панель управления -->
                    <RowDefinition Height="*"/>
                    <!-- Контент -->
                </Grid.RowDefinitions>

                <!--Панель управления (свернуть, закрыть)-->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            FlowDirection="RightToLeft"
                            Background="Transparent"
                            MouseLeftButtonDown="pnlControlBar_MouseLeftButtonDown">

                    <StackPanel.Resources>
                        <!-- Стили для кнопок управления окном (можно вынести в отдельный файл) -->
                        <Style x:Key="WindowControlButton" TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#344E41"/>
                            <Setter Property="Width" Value="40"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <fa:IconImage Icon="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                          Foreground="{TemplateBinding Foreground}"
                                                          Height="12" Width="12"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>

                    <Button Style="{StaticResource WindowCloseButton}" Tag="Xmark" Click="CloseButton_Click"/>
                    <Button Style="{StaticResource WindowControlButton}" Tag="WindowMaximize" Click="MaximizeButton_Click"/>
                    <Button Style="{StaticResource WindowControlButton}" Tag="WindowMinimize" Click="MinimizeButton_Click" />
                </StackPanel>

                <!--_Область для отображения контента (View)_-->
                <!-- Сюда будут загружаться ваши UserControls (Dashboard, Customers и т.д.) -->
                <ContentControl Grid.Row="1" Margin="30 10 30 20"
                                Content="{Binding CurrentView}"/>

            </Grid>
        </Grid>
    </Border>
</Window>
